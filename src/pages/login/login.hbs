{{#> form-page-layout}}
<h1 class="form-header form-block__header">Вход</h1>
{{#> custom-form className="form" action="/" method="POST" id="login-form" }}
    {{{ InputBlock block="login" type="text" label="Логин" name="login"}}}
    {{{ InputBlock block="login" type="password" label="Пароль" name="password" }}}
    {{{ Button className="button form-block__button" type="submit" text="Войти" }}}
{{/custom-form}}
<div class="form-block__link-wrapper">
    {{{ Link className="link form-block__link" href="/registration" text="Нет аккаунта?" }}}
</div>
{{/form-page-layout }}
